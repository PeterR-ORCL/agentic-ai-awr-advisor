AWRAI_APP@AWRAI_high> CREATE OR REPLACE VIEW VW_AWR_REPORT_LATEST AS
  2  SELECT
  3      s.SOURCE_SYSTEM_CODE,
  4      s.CUSTOMER_NAME,
  5      s.ENVIRONMENT_NAME,
  6      r.AWR_ID,
  7      r.DB_NAME,
  8      r.DBID,
  9      r.INSTANCE_NAME,
 10      r.INSTANCE_NUMBER,
 11      r.SNAP_ID_BEGIN,
 12      r.SNAP_ID_END,
 13      r.SNAP_TIME_BEGIN,
 14      r.SNAP_TIME_END,
 15      r.SNAP_ELAPSED_MINUTES,
 16      r.PARSE_STATUS,
 17      r.ANOMALY_FLAG,
 18      r.INGEST_MODE,
 19      r.SOURCE_FILE_NAME,
 20      r.CREATED_AT
 21  FROM AWR_REPORT r
 22  JOIN AWR_SOURCE_SYSTEM s
 23    ON s.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
 24  WHERE r.SNAP_TIME_END = (
 25      SELECT MAX(r2.SNAP_TIME_END)
 26      FROM AWR_REPORT r2
 27      WHERE r2.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
 28  );
Elapsed: 00:00:00.176
AWRAI_APP@AWRAI_high>
AWRAI_APP@AWRAI_high> CREATE OR REPLACE VIEW VW_AWR_RECOMMENDATION_CYCLE AS
  2  SELECT
  3      s.SOURCE_SYSTEM_CODE,
  4      r.AWR_ID,
  5      r.SNAP_TIME_END,
  6      sr.SCORE_RESULT_ID,
  7      sr.DECISION_DOMAIN,
  8      sr.TOTAL_SCORE,
  9      sr.RISK_LEVEL,
 10      rec.RECOMMENDATION_ID,
 11      rec.RECOMMENDATION_TYPE,
 12      rec.STATUS AS RECOMMENDATION_STATUS,
 13      act.ACTION_ID,
 14      act.ACTION_TYPE,
 15      act.ACTION_STATUS,
 16      o.OUTCOME_ID,
 17      o.OUTCOME_STATUS,
 18      o.SUCCESS_FLAG
 19  FROM AWR_REPORT r
 20  JOIN AWR_SOURCE_SYSTEM s
 21    ON s.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
 22  LEFT JOIN AWR_SCORE_RESULT sr
 23    ON sr.AWR_ID = r.AWR_ID
 24  LEFT JOIN AWR_RECOMMENDATION rec
 25    ON rec.SCORE_RESULT_ID = sr.SCORE_RESULT_ID
 26  LEFT JOIN AWR_ACTION act
 27    ON act.RECOMMENDATION_ID = rec.RECOMMENDATION_ID
 28  LEFT JOIN AWR_OUTCOME o
 29    ON o.ACTION_ID = act.ACTION_ID;
Elapsed: 00:00:00.163
