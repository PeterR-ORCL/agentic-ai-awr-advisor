198              'TOP_SQL_LOAD_CONCENTRATION',
199              'HARD_PARSES_PER_SEC',
200              'HARD_PARSE_PCT',
201              'SOFT_PARSE_PCT',
202              'BUFFER_CACHE_HIT_RATIO_PCT',
203              'LIBRARY_CACHE_HIT_RATIO_PCT',
204              'PARSE_CPU_TO_PARSE_ELAPSED_PCT',
205              'PGA_CACHE_HIT_PCT',
206              'THROUGHPUT_USER_CALLS_PER_SEC',
207              'TRANSACTIONS_PER_SEC',
208              'TEMP_IO_PRESSURE',
209              'PGA_SPILL_PRESSURE',
210              'TEMP_SPILL_PCT',
211              'SORTS_DISK_PCT',
212              'WORKAREA_ONEPASS_PCT',
213              'WORKAREA_MULTIPASS_PCT',
214              'USER_IO_PRESSURE',
215              'COMMIT_PRESSURE',
216              'CONCURRENCY_PRESSURE',
217              'NETWORK_WAIT_PCT_DB_TIME',
218              'CURSOR_MUTEX_WAIT_PCT_DB_TIME',
219              'READ_MB_PER_SEC',
220              'WRITE_MB_PER_SEC'
221          ) THEN 'GENERAL'
222          WHEN METRIC_NAME IN (
