,cyan [AWRAI_APP]@AWRAI_high >
,cyan [AWRAI_APP]@AWRAI_high > CREATE OR REPLACE VIEW VW_AWR_SCOPE_CONTEXT AS
  2  WITH report_scope_candidates AS (
  3      SELECT
  4          r.*,
  5          COALESCE(
  6              r.DBID,
  7              JSON_VALUE(
  8                  r.RAW_METADATA_JSON,
  9                  '$.dbid' RETURNING NUMBER NULL ON ERROR
 10              )
 11          ) AS RESOLVED_DBID,
 12          COALESCE(
 13              r.INSTANCE_NUMBER,
 14              JSON_VALUE(
 15                  r.RAW_METADATA_JSON,
 16                  '$.instance_number' RETURNING NUMBER NULL ON ERROR
 17              )
 18          ) AS RESOLVED_INSTANCE_NUMBER,
 19          CASE
 20              WHEN COALESCE(
 21                  r.DBID,
 22                  JSON_VALUE(
 23                      r.RAW_METADATA_JSON,
 24                      '$.dbid' RETURNING NUMBER NULL ON ERROR
 25                  )
 26              ) IS NOT NULL
 27               AND COALESCE(
 28                  r.INSTANCE_NUMBER,
 29                  JSON_VALUE(
 30                      r.RAW_METADATA_JSON,
 31                      '$.instance_number' RETURNING NUMBER NULL ON ERROR
 32                  )
 33              ) IS NOT NULL
 34               AND r.SNAP_ID_BEGIN IS NOT NULL
 35               AND r.SNAP_ID_END IS NOT NULL
 36               AND r.SNAP_TIME_BEGIN IS NOT NULL
 37               AND r.SNAP_TIME_END IS NOT NULL
 38              THEN 1
 39              ELSE 0
 40          END AS HAS_LOGICAL_SNAPSHOT_ID
 41      FROM AWR_REPORT r
 42  ),
 43  canonical_report_per_scope AS (
 44      SELECT
 45          c.*,
 46          ROW_NUMBER() OVER (
 47              PARTITION BY
 48                  c.SOURCE_SYSTEM_ID,
 49                  CASE
 50                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 51                      THEN 'LOGICAL_SNAPSHOT'
 52                      ELSE 'FILE_HASH'
 53                  END,
 54                  CASE
 55                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 56                      THEN c.RESOLVED_DBID
 57                  END,
 58                  CASE
 59                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 60                      THEN c.RESOLVED_INSTANCE_NUMBER
 61                  END,
 62                  CASE
 63                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 64                      THEN c.SNAP_ID_BEGIN
 65                  END,
 66                  CASE
 67                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 68                      THEN c.SNAP_ID_END
 69                  END,
 70                  CASE
 71                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 72                      THEN c.SNAP_TIME_BEGIN
 73                  END,
 74                  CASE
 75                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 1
 76                      THEN c.SNAP_TIME_END
 77                  END,
 78                  CASE
 79                      WHEN c.HAS_LOGICAL_SNAPSHOT_ID = 0
 80                      THEN c.FILE_HASH_SHA256
 81                  END
 82              ORDER BY c.CREATED_AT DESC, c.AWR_ID DESC
 83          ) AS RN
 84      FROM report_scope_candidates c
 85  ),
 86  canonical_report_set AS (
 87      SELECT *
 88      FROM canonical_report_per_scope
 89      WHERE RN = 1
 90  ),
 91  latest_feature_per_awr AS (
 92      SELECT
 93          fv.AWR_ID,
 94          fv.SOURCE_SYSTEM_ID,
 95          fv.FEATURE_VECTOR_ID,
 96          fv.OBSERVED_AT,
 97          fv.TOPOLOGY_CLASS,
 98          fv.PLATFORM_CLASS,
 99          fv.EVENT_CLASS,
100          ROW_NUMBER() OVER (
101              PARTITION BY fv.AWR_ID, fv.SOURCE_SYSTEM_ID
102              ORDER BY fv.OBSERVED_AT DESC, fv.FEATURE_VECTOR_ID DESC
103          ) AS RN
104      FROM AWR_FEATURE_VECTOR fv
105      JOIN canonical_report_set cr
106        ON cr.AWR_ID = fv.AWR_ID
107       AND cr.SOURCE_SYSTEM_ID = fv.SOURCE_SYSTEM_ID
108  ),
109  latest_score_per_awr AS (
110      SELECT
111          sr.AWR_ID,
112          sr.SOURCE_SYSTEM_ID,
113          sr.SCORE_RESULT_ID,
114          sr.SCORED_AT,
115          sr.TOPOLOGY_CLASS,
116          sr.PLATFORM_CLASS,
117          sr.EVENT_CLASS,
118          ROW_NUMBER() OVER (
119              PARTITION BY sr.AWR_ID, sr.SOURCE_SYSTEM_ID
120              ORDER BY sr.SCORED_AT DESC, sr.SCORE_RESULT_ID DESC
121          ) AS RN
122      FROM AWR_SCORE_RESULT sr
123      JOIN canonical_report_set cr
124        ON cr.AWR_ID = sr.AWR_ID
125       AND cr.SOURCE_SYSTEM_ID = sr.SOURCE_SYSTEM_ID
126  )
127  SELECT
128      r.AWR_ID,
129      r.SOURCE_SYSTEM_ID,
130      s.SOURCE_SYSTEM_CODE,
131      COALESCE(r.DB_NAME, s.DB_NAME, s.DB_UNIQUE_NAME) AS DB_NAME,
132      COALESCE(r.RESOLVED_DBID, s.DBID) AS DBID,
133      COALESCE(
134          r.HOST_NAME,
135          s.PRIMARY_HOST_NAME,
136          JSON_VALUE(
137              r.RAW_METADATA_JSON,
138              '$.host_name' RETURNING VARCHAR2(256) NULL ON ERROR
139          )
140      ) AS HOST_NAME,
141      COALESCE(
142          r.INSTANCE_NAME,
143          JSON_VALUE(
144              r.RAW_METADATA_JSON,
145              '$.instance_name' RETURNING VARCHAR2(128) NULL ON ERROR
146          )
147      ) AS INSTANCE_NAME,
148      r.RESOLVED_INSTANCE_NUMBER AS INSTANCE_NUMBER,
149      r.SNAP_TIME_BEGIN AS SNAP_BEGIN_TIME,
150      r.SNAP_TIME_END AS SNAP_END_TIME,
151      COALESCE(
152          r.DB_VERSION,
153          s.DB_VERSION,
154          JSON_VALUE(
155              r.RAW_METADATA_JSON,
156              '$.db_version' RETURNING VARCHAR2(64) NULL ON ERROR
157          )
158      ) AS DB_VERSION,
159      COALESCE(
160          s.DATABASE_ROLE,
161          JSON_VALUE(
162              r.PARSER_OUTPUT_JSON,
163              '$.topology_signals.database_role' RETURNING VARCHAR2(64)
164              NULL ON ERROR
165          ),
166          JSON_VALUE(
167              s.TAGS_JSON,
168              '$.database_role' RETURNING VARCHAR2(64) NULL ON ERROR
169          )
170      ) AS DATABASE_ROLE,
171      COALESCE(
172          s.INSTANCE_COUNT,
173          JSON_VALUE(
174              r.PARSER_OUTPUT_JSON,
175              '$.topology_signals.instance_count' RETURNING NUMBER NULL ON ERROR
176          ),
177          JSON_VALUE(
178              s.TAGS_JSON,
179              '$.instance_count' RETURNING NUMBER NULL ON ERROR
180          )
181      ) AS INSTANCE_COUNT,
182      COALESCE(
183          r.PLATFORM_NAME,
184          s.PLATFORM_NAME,
185          JSON_VALUE(
186              r.RAW_METADATA_JSON,
187              '$.platform' RETURNING VARCHAR2(256) NULL ON ERROR
188          )
189      ) AS PLATFORM,
190      COALESCE(
191          fv.TOPOLOGY_CLASS,
192          ls.TOPOLOGY_CLASS,
193          JSON_VALUE(
194              r.PARSER_OUTPUT_JSON,
195              '$.topology_signals.topology_class' RETURNING VARCHAR2(64)
196              NULL ON ERROR
197          ),
198          JSON_VALUE(
199              s.TAGS_JSON,
200              '$.topology_class' RETURNING VARCHAR2(64) NULL ON ERROR
201          )
202      ) AS TOPOLOGY_CLASS,
203      COALESCE(
204          fv.PLATFORM_CLASS,
205          ls.PLATFORM_CLASS,
206          JSON_VALUE(
207              r.PARSER_OUTPUT_JSON,
208              '$.topology_signals.platform_class' RETURNING VARCHAR2(64)
209              NULL ON ERROR
210          ),
211          JSON_VALUE(
212              s.TAGS_JSON,
213              '$.platform_class' RETURNING VARCHAR2(64) NULL ON ERROR
214          )
215      ) AS PLATFORM_CLASS
216  FROM canonical_report_set r
217  JOIN AWR_SOURCE_SYSTEM s
218    ON s.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
219  LEFT JOIN latest_feature_per_awr fv
220    ON fv.AWR_ID = r.AWR_ID
221   AND fv.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
222   AND fv.RN = 1
223  LEFT JOIN latest_score_per_awr ls
224    ON ls.AWR_ID = r.AWR_ID
225   AND ls.SOURCE_SYSTEM_ID = r.SOURCE_SYSTEM_ID
226   AND ls.RN = 1;

