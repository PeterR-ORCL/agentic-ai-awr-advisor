{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_analysis.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Run Parser (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_parser.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Inspect Sections",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/inspect_sections.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Run AWR → ADB Loader",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ingest/awr_adb_loader.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
